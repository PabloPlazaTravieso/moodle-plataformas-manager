{{!
    @template local_miplugin/mobile_notes_list

    Read-only notes list rendered inside the Moodle App (Ionic webview).
    Kept intentionally simple/static since this integration is unverified
    against a real app instance.

    Context variables required for this template:
    * notes - array of {content, userfullname, timecreated}
}}
<ion-list>
    {{#notes}}
    <ion-item>
        <ion-label>
            <p>{{content}}</p>
            <p><i>{{userfullname}} - {{timecreated}}</i></p>
        </ion-label>
    </ion-item>
    {{/notes}}
    {{^notes}}
    <ion-item>
        <ion-label>{{#str}} nonotes, local_miplugin {{/str}}</ion-label>
    </ion-item>
    {{/notes}}
</ion-list>
