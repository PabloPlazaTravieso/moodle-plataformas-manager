{{!
    @template local_miplugin/notes_list

    Renders the list of notes attached to a course.

    Context variables required for this template:
    * notes - array of {id, content, userfullname, timecreated}
}}
<ul class="list-group">
    {{#notes}}
    <li class="list-group-item d-flex justify-content-between align-items-start">
        <div>
            <p class="mb-1">{{content}}</p>
            <small class="text-muted">{{userfullname}} &middot; {{timecreated}}</small>
        </div>
        <button
            type="button"
            class="btn btn-sm btn-outline-danger ms-3"
            data-action="delete-note"
            data-note-id="{{id}}"
        >
            {{#str}} deletenote, local_miplugin {{/str}}
        </button>
    </li>
    {{/notes}}
    {{^notes}}
    <li class="list-group-item">{{#str}} nonotes, local_miplugin {{/str}}</li>
    {{/notes}}
</ul>
